# Copy to .env and adjust as needed.
#
# If/when a site requires JavaScript rendering, Playwright browser binaries
# can be installed into a project-local directory (kept out of git) with:
#
#     PLAYWRIGHT_BROWSERS_PATH=playwright-browsers python -m playwright install chromium
#
# Setting this env var keeps the downloaded browsers inside the repo folder
# (gitignored) instead of the global cache. Not required for the pilot.
PLAYWRIGHT_BROWSERS_PATH=playwright-browsers
